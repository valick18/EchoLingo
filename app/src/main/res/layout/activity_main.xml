<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:paddingTop="48dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EchoLingo"
                android:textColor="@color/text_main"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Вивчення німецької"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>
                
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">
                
                <TextView
                    android:id="@+id/tv_total_learned"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                    
                <TextView
                    android:id="@+id/btn_view_learned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Вивчені →"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="@drawable/btn_glass"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="24sp"
            android:padding="8dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:background="@drawable/btn_glass"/>
    </RelativeLayout>

    <!-- Topics List -->
    <ScrollView
        android:id="@+id/scroll_topics"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottom_bar"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/topics_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingBottom="8dp"/>
    </ScrollView>

    <!-- Bottom Bar: ONE listen button -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/btn_nav_learned"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎧 Слухати"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="14dp"
            android:background="@drawable/btn_primary"/>
    </LinearLayout>
</RelativeLayout>
